# 疯狂发明家技术雷达 - 环境变量配置
# 复制此文件为 .env 并填入真实的 key

# Gemini API Key
# 获取方式: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Telegram Bot Token
# 获取方式: 在 Telegram 中找 @BotFather，发送 /newbot
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID
# 获取方式: 启动 bot 后访问 https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
